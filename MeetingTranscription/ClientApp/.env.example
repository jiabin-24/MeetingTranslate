# Example build-time environment variables for this project
# Copy to .env and fill values before running `npm run build`.
REACT_APP_API_BASE=https://api.example.com
REACT_APP_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=YOUR_KEY_HERE;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
REACT_APP_USE_BYTE_DANCE=false
